{
  "name": "litomi",
  "version": "1.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev & bun dev:vercel & bun dev:backend",
    "dev:backend": "bun kill:backend && bun run --conditions=react-server --env-file=.env.development --hot src/backend/index.ts",
    "dev:vercel": "bun kill:vercel && cd vercel && next dev -p 3001",
    "dev:prod": "env-cmd -f .env.production bun dev",
    "kill:nextjs": "kill -9 $(lsof -ti tcp:3000) 2>/dev/null || true",
    "kill:vercel": "kill -9 $(lsof -ti tcp:3001) 2>/dev/null || true",
    "kill:backend": "kill -9 $(lsof -ti tcp:3002) 2>/dev/null || true",
    "build": "next build",
    "build:all": "next build && bun build:vercel",
    "build:vercel": "cd vercel && next build",
    "build:backend": "docker build -t litomi-backend-local .",
    "start": "next start",
    "start:all": "next start & bun start:vercel",
    "start:vercel": "cd vercel && next start -p 3001",
    "start:backend": "docker run --rm -p 3002:3002 --env-file .env.docker litomi-backend-local",
    "lint": "eslint --fix",
    "analyze": "ANALYZE=true next build --webpack",
    "format": "prettier --write .",
    "type": "tsc --noEmit",
    "prepare": "husky",
    "clean": "rm -rf .next node_modules/.cache",
    "crawl:manga:aiven": "bun --conditions=react-server cloud-run/manga-crawl/src/index.ts",
    "db": "docker compose down -v && docker compose up -d --wait && bun db:push",
    "db:push": "bun run db:push:supabase",
    "db:push:prod": "bun run db:push:supabase:prod && bun run db:push:aiven:prod",
    "db:push:aiven": "NODE_OPTIONS='--conditions=react-server' drizzle-kit push --config=drizzle.aiven.config.ts",
    "db:push:aiven:prod": "DB_ENV=production NODE_OPTIONS='--conditions=react-server' bun run db:push:aiven",
    "db:push:d1": "NODE_OPTIONS='--conditions=react-server' drizzle-kit push --config=drizzle.d1.config.ts",
    "db:push:neon": "NODE_OPTIONS='--conditions=react-server' drizzle-kit push --config=drizzle.neon.config.ts",
    "db:push:neon:prod": "DB_ENV=production NODE_OPTIONS='--conditions=react-server' bun run db:push:neon",
    "db:push:supabase": "NODE_OPTIONS='--conditions=react-server' drizzle-kit push --config=drizzle.supabase.config.ts",
    "db:push:supabase:prod": "DB_ENV=production NODE_OPTIONS='--conditions=react-server' bun run db:push:supabase",
    "test:watch": "bun test --watch",
    "test:coverage": "bun test --coverage",
    "notify": "bun --conditions=react-server cloud-run/crawl-and-notify/src/index.ts",
    "grant:libo": "bun --conditions=react-server tools/grantLibo.ts"
  },
  "dependencies": {
    "@amplitude/analytics-browser": "^2.36.7",
    "@amplitude/analytics-client-common": "2.4.37",
    "@amplitude/analytics-node": "^1.5.47",
    "@capacitor/core": "8.3.0",
    "@fingerprintjs/fingerprintjs": "^5.1.0",
    "@google-analytics/data": "^5.2.1",
    "@hono/otel": "^1.1.1",
    "@hono/zod-validator": "^0.7.6",
    "@marsidev/react-turnstile": "^1.4.2",
    "@mlc-ai/web-llm": "^0.2.82",
    "@mrjasonroy/cache-components-cache-handler": "^16.1.6",
    "@next/third-parties": "16.1.7",
    "@opentelemetry/exporter-trace-otlp-http": "^0.212.0",
    "@opentelemetry/sdk-node": "^0.212.0",
    "@sentry/nextjs": "10.34.0",
    "@simplewebauthn/browser": "^13.3.0",
    "@simplewebauthn/server": "^13.3.0",
    "@suspensive/react": "^3.19.6",
    "@t3-oss/env-core": "^0.13.10",
    "@t3-oss/env-nextjs": "^0.13.10",
    "@tanstack/react-query": "^5.90.21",
    "@tanstack/react-query-devtools": "^5.91.3",
    "@upstash/redis": "^1.37.0",
    "@vercel/functions": "^3.4.3",
    "@vercel/otel": "^2.1.1",
    "baseline-browser-mapping": "^2.10.8",
    "bcryptjs": "^3.0.3",
    "caniuse-lite": "^1.0.30001780",
    "country-flag-icons": "^1.6.15",
    "dayjs": "^1.11.20",
    "drizzle-orm": "^0.45.1",
    "hono": "^4.12.8",
    "ioredis": "^5.10.0",
    "jose": "^6.2.1",
    "js-cookie": "^3.0.5",
    "jszip": "^3.10.1",
    "lucide-react": "^0.562.0",
    "ms": "^2.1.3",
    "next": "16.1.7",
    "node-html-parser": "^7.1.0",
    "otplib": "^13.3.0",
    "p-limit": "^7.3.0",
    "postgres": "^3.4.8",
    "qrcode": "^1.5.4",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-intersection-observer": "^10.0.3",
    "react-textarea-autosize": "^8.5.9",
    "react-window": "^2.2.7",
    "server-only": "^0.0.1",
    "sharp": "^0.34.5",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "web-push": "^3.6.7",
    "ws": "^8.19.0",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^9.39.4",
    "@next/bundle-analyzer": "16.1.7",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4.2.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/bun": "^1.3.10",
    "@types/country-flag-icons": "^1.2.2",
    "@types/js-cookie": "^3.0.6",
    "@types/jszip": "^3.4.1",
    "@types/ms": "^2.1.0",
    "@types/node": "^25.5.0",
    "@types/qrcode": "^1.5.6",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@types/web-push": "^3.6.4",
    "@types/ws": "^8.18.1",
    "@webgpu/types": "^0.1.69",
    "babel-plugin-react-compiler": "^1.0.0",
    "bun": "^1.3.10",
    "dotenv": "^17.3.1",
    "drizzle-kit": "^0.31.10",
    "env-cmd": "^11.0.0",
    "eslint": "^9.39.4",
    "eslint-config-flat-gitignore": "^2.2.1",
    "eslint-config-next": "16.1.7",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-perfectionist": "^5.7.0",
    "eslint-plugin-react": "^7.37.5",
    "globals": "^17.4.0",
    "happy-dom": "^20.8.4",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "3.8.1",
    "schema-dts": "^1.1.5",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.1",
    "wrangler": "^4.75.0"
  }
}
